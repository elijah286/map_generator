{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "caches": {
    "node_modules": "web/node_modules"
  },
  "steps": {
    "install": {
      "commands": [
        {
          "cmd": "npm ci --prefix web",
          "customName": "Install Node dependencies (web/)"
        }
      ]
    }
  },
  "deploy": {
    "startCommand": "npm start --prefix web"
  }
}
